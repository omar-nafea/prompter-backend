includes:
    - vendor/larastan/larastan/extension.neon
parameters:
    paths:
        - app/
        - Modules/
    excludePaths:
        - **/tests/**
        - Modules/CRUDGenerator/**/**
        - **/**/**/Database/Factories/**
    level: 9
    checkModelProperties: true
    ignoreErrors:
        #- '#Call to an undefined static method Illuminate\\Support\\Str::minify\(\)#'
