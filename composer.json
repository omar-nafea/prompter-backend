{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": ["laravel", "framework"],
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "archtechx/enums": "^1.0",
        "guzzlehttp/guzzle": "^7.2",
        "laravel/framework": "^10.10",
        "laravel/prompts": "^0.1.19",
        "laravel/sanctum": "^3.3",
        "laravel/tinker": "^2.8",
        "mohamed-gaber/api-response": "dev-master as 1.0.0",
        "mohamed-gaber/pipeline-filter": "dev-master as 1.0.0",
        "mohamed-gaber/unique-model-key-generator": "dev-master as 1.0.0",
        "mohamedgaber-intake40/sanctum-refresh-token": "^2.3",
        "nwidart/laravel-modules": "^10.0",
        "pascaldevink/shortuuid": "^4.0",
        "saloonphp/saloon": "^3.0",
        "spatie/laravel-data": "^4.5"
    },
    "require-dev": {
        "fakerphp/faker": "^1.9.1",
        "glhd/laravel-dumper": "^2.0",
        "lanin/laravel-api-debugger": "^4.0",
        "laradumps/laradumps": "^3.0",
        "larastan/larastan": "^2.0",
        "laravel/pint": "^1.0",
        "laravel/sail": "^1.18",
        "mockery/mockery": "^1.4.4",
        "nunomaduro/collision": "^7.0",
        "pestphp/pest": "^2.34",
        "pestphp/pest-plugin-type-coverage": "^2.8",
        "spatie/laravel-ignition": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/",
            "Modules\\": "Modules/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ],
        "lint": "pint",
        "test:lint": "pint --test",
        "test:unit": "./vendor/bin/pest --order-by random",
        "test:static": "phpstan analyse",
        "test:type-coverage": "pest --type-coverage --min=100",
        "test": [
            "@test:lint",
            "@test:unit",
            "@test:static"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true,
            "wikimedia/composer-merge-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "repositories": [
        {
            "type": "path",
            "url": "Packages/ApiResponse"
        },
        {
            "type": "path",
            "url": "Packages/PipelineFilter"
        },
        {
            "type": "path",
            "url": "Packages/UniqueModelKeyGenerator"
        }
    ]
}
